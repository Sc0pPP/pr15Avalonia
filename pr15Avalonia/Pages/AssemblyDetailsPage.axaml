<nav:Page xmlns="https://github.com/avaloniaui"
          xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
          xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
          xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
          xmlns:nav="clr-namespace:WpfLikeAvaloniaNavigation;assembly=WpfLikeAvaloniaNavigation"
          xmlns:models="clr-namespace:pr15Avalonia.Models"
          xmlns:asyncImageLoader="clr-namespace:AsyncImageLoader;assembly=AsyncImageLoader.Avalonia"
          mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
          x:Class="pr15Avalonia.Pages.AssemblyDetailsPage">

    <Grid Background="#F0F4F8">
        <Border Background="White"
                CornerRadius="12"
                BoxShadow="0 4 16 0 #1A000000"
                Margin="16" Padding="20">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" BorderThickness="1" BorderBrush="Gray" Margin="10,10,10,5" CornerRadius="6">
                    <StackPanel Orientation="Horizontal" Spacing="10" Margin="10">
                        <TextBlock x:Name="TitleText" FontSize="20" FontWeight="SemiBold"/>
                        <Button Content="Назад" Width="130" Background="Bisque" Click="Back_Click"/>
                    </StackPanel>
                </Border>

                <Border Grid.Row="1" BorderThickness="1" BorderBrush="Gray" Margin="10,5,10,10" CornerRadius="6">
                    <ListBox ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                             x:Name="PartsListBox"
                             Margin="10">
                        <ListBox.ItemTemplate>
                            <DataTemplate x:DataType="models:Basepart">
                                <Border BorderBrush="LightGray"
                                        BorderThickness="1"
                                        CornerRadius="8"
                                        Padding="15"
                                        Margin="5"
                                        Background="White">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="150"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <Image Grid.Column="0"
                                               Width="130" Height="130"
                                               Stretch="Uniform"
                                               Margin="0,0,15,0"
                                               asyncImageLoader:ImageLoader.Source="{Binding Image}"/>

                                        <StackPanel Grid.Column="1" Spacing="8">
                                            <TextBlock Text="{Binding Name}"
                                                       FontWeight="Bold"
                                                       FontSize="18"
                                                       TextWrapping="Wrap"/>
                                            <TextBlock Text="{Binding Manufacturer.Name}"
                                                       FontSize="14"
                                                       Foreground="Gray"/>
                                            <TextBlock Text="{Binding Price, StringFormat='{}{0:N0} ₽'}"
                                                       FontSize="20"
                                                       FontWeight="Bold"
                                                       Foreground="Green"
                                                       Margin="0,10,0,0"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                        <ListBox.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel/>
                            </ItemsPanelTemplate>
                        </ListBox.ItemsPanel>
                    </ListBox>
                </Border>

                <Border Grid.Row="2" Margin="10,0,10,10">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <TextBlock x:Name="TotalText"
                                   FontSize="20"
                                   FontWeight="Bold"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>

            </Grid>
        </Border>
    </Grid>
</nav:Page>