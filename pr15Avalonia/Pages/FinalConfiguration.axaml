<nav:Page xmlns="https://github.com/avaloniaui"
          xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
          xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
          xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
          xmlns:nav="clr-namespace:WpfLikeAvaloniaNavigation;assembly=WpfLikeAvaloniaNavigation"
          mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
          x:Class="pr15Avalonia.Pages.FinalConfiguration">

    <Grid Background="#F0F4F8">
        <Border Background="White"
                CornerRadius="12"
                BoxShadow="0 4 16 0 #1A000000"
                Margin="16" Padding="20">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Заголовок -->
                <Border Grid.Row="0" BorderThickness="1" BorderBrush="Gray" Margin="10,10,10,5" CornerRadius="6">
                    <StackPanel Orientation="Horizontal" Spacing="10" Margin="10">
                        <TextBlock Text="Ваша сборка" FontSize="20" FontWeight="SemiBold"/>
                        <Button Content="Вернуться на начальное окно" Width="130" Background="Bisque" Click="Back_Click"/>
                    </StackPanel>
                </Border>

                <!-- Список компонентов -->
                <Border Grid.Row="1" BorderThickness="1" BorderBrush="Gray" Margin="10,5,10,10" CornerRadius="6">
                    <ScrollViewer>
                        <StackPanel Margin="15" Spacing="8">
                            <TextBlock x:Name="CpuText" FontSize="15"/>
                            <TextBlock x:Name="GpuText" FontSize="15"/>
                            <TextBlock x:Name="MotherboardText" FontSize="15"/>
                            <TextBlock x:Name="RamText" FontSize="15"/>
                            <TextBlock x:Name="CaseText" FontSize="15"/>
                            <TextBlock x:Name="PowerText" FontSize="15"/>
                            <TextBlock x:Name="CoolerText" FontSize="15"/>
                            <TextBlock x:Name="StorageText" FontSize="15"/>
                            <Separator Margin="0,10"/>
                            <TextBlock x:Name="TotalPriceText" FontSize="20" FontWeight="Bold"/>
                        </StackPanel>
                    </ScrollViewer>
                </Border>

                <!-- Кнопки -->
                <Border Grid.Row="2" Margin="10,0,10,10">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="10">
                        <TextBox x:Name="AuthorNameBox"
                                 Watermark="Автор..."
                                 Width="150"
                                 VerticalAlignment="Center"/>
                        <TextBox x:Name="AssemblyNameBox"
                                 Watermark="Название сборки..."
                                 Width="200"
                                 VerticalAlignment="Center"/>
                        <Button Content="Сохранить сборку"
                                Width="160" Height="40"
                                Background="Green" Foreground="White"
                                FontSize="16"
                                Click="SaveAssembly_Click"/>
                    </StackPanel>
                </Border>

            </Grid>
        </Border>
    </Grid>
</nav:Page>